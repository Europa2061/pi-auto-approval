{
  "name": "pi-auto-approval",
  "version": "0.1.0",
  "description": "AI classifier based automatic approval extension for Pi coding agent.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "tests",
    "config",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx tests/run-tests.ts",
    "smoke:pi": "node --import tsx tests/pi-smoke.ts",
    "check": "npm run typecheck && npm run test"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "auto-review",
    "permissions"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@oh-my-pi/pi-ai": "*",
    "@oh-my-pi/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@oh-my-pi/pi-ai": {
      "optional": true
    },
    "@oh-my-pi/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
